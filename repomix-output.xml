<file path="internal/models/todo_view.go">
package models

import (
	"fmt"
	"todo_cli/internal/ui"

	tea "charm.land/bubbletea/v2"
)

func (m model) View() tea.View {
	s := ui.Wh.Render("Todo App") + "\n\n"

	for i, todo := range m.todos {

		itemStyle := ui.Task
		cursor := " "

		if m.cursor == i {
			cursor = ui.Cursor.Render(">")
		}

		checked := "[ ]"
		if m.selected[i] == true {
			checked = ui.Completed.Render("[X]")
			itemStyle = ui.Completed
		}

		s += fmt.Sprintf("%s %s %s\n", cursor, checked, itemStyle.Render(todo))
	}
	return tea.NewView(s + "\n" + m.help.RenderShort() + "\n")
}
